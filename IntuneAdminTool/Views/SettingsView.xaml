<UserControl x:Class="IntuneAdminTool.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20" MaxWidth="600" HorizontalAlignment="Left">
            <TextBlock Text="Settings" FontSize="24" FontWeight="Light" Margin="0,0,0,24" Foreground="#323130"/>

            <!-- Authentication Settings -->
            <TextBlock Text="Authentication" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,12" Foreground="#0078D4"/>

            <TextBlock Text="Client ID (App Registration)" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBlock Text="Leave empty to use the default Microsoft Graph Command Line Tools app." 
                       Foreground="#605E5C" FontSize="11" Margin="0,0,0,4"/>
            <TextBox Text="{Binding ClientId, UpdateSourceTrigger=PropertyChanged}" 
                     Padding="8" Width="500" HorizontalAlignment="Left" IsReadOnly="{Binding IsLocked}"/>

            <TextBlock Text="Tenant ID" FontWeight="SemiBold" Margin="0,16,0,4"/>
            <TextBlock Text="Azure AD Tenant ID or domain. Use 'organizations' for multi-tenant." 
                       Foreground="#605E5C" FontSize="11" Margin="0,0,0,4"/>
            <TextBox Text="{Binding TenantId, UpdateSourceTrigger=PropertyChanged}" 
                     Padding="8" Width="500" HorizontalAlignment="Left" IsReadOnly="{Binding IsLocked}"/>

            <!-- Signed-in notice -->
            <TextBlock Text="Sign out to modify these settings."
                       Foreground="#A80000" FontSize="12" Margin="0,8,0,0"
                       Visibility="{Binding IsLocked, Converter={StaticResource BoolToVisibility}}"/>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" Margin="0,24,0,0" Visibility="{Binding IsLocked, Converter={StaticResource InverseBoolToVisibility}}">
                <Button Content="Save Settings" Command="{Binding SaveSettingsCommand}" 
                        Padding="16,8" Style="{StaticResource PrimaryButtonStyle}" />
                <Button Content="Reset to Defaults" Command="{Binding ResetToDefaultsCommand}" 
                        Padding="16,8" Margin="12,0,0,0" />
            </StackPanel>

            <!-- Status -->
            <TextBlock Text="{Binding StatusMessage}" Margin="0,16,0,0" Foreground="#605E5C" FontStyle="Italic"
                       Visibility="{Binding StatusMessage, Converter={StaticResource NullToCollapsed}}"/>

            <!-- Info -->
            <Border Background="#F3F2F1" CornerRadius="4" Padding="16" Margin="0,32,0,0">
                <StackPanel>
                    <TextBlock Text="About" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBlock Text="Microsoft Intune Admin Tool" Margin="0,2"/>
                    <TextBlock Text="A desktop client for managing Microsoft Intune resources." 
                               Foreground="#605E5C" Margin="0,2" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
