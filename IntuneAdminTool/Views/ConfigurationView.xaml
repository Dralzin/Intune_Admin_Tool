<UserControl x:Class="IntuneAdminTool.Views.ConfigurationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Search / Filter Bar -->
        <StackPanel Orientation="Horizontal" Margin="10">
            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Width="300" Padding="5" VerticalContentAlignment="Center"/>
            <ComboBox ItemsSource="{Binding PlatformFilterOptions}" SelectedItem="{Binding SelectedPlatformFilter}" Width="150" Margin="5,0" Padding="5" VerticalContentAlignment="Center"/>
            <ComboBox ItemsSource="{Binding ProfileTypeFilterOptions}" SelectedItem="{Binding SelectedProfileTypeFilter}" Width="200" Margin="5,0" Padding="5" VerticalContentAlignment="Center"/>
            <Button Content="Search" Command="{Binding SearchCommand}" Margin="5,0" Padding="10,5"/>
        </StackPanel>

        <TextBlock Grid.Row="1" Text="Loading configurations..." Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}" HorizontalAlignment="Center" Margin="0,10"/>
        <DataGrid Grid.Row="1" ItemsSource="{Binding Configurations}" SelectedItem="{Binding SelectedConfiguration}" AutoGenerateColumns="False" IsReadOnly="True" Margin="10" CanUserSortColumns="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Display Name" Binding="{Binding DisplayName}" Width="250"/>
                <DataGridTextColumn Header="Profile Type" Binding="{Binding ProfileType}" Width="220"/>
                <DataGridTextColumn Header="Platform" Binding="{Binding Platform}" Width="100"/>
                <DataGridTextColumn Header="Created" Binding="{Binding CreatedDateTime, StringFormat=g}" Width="140"/>
                <DataGridTextColumn Header="Last Modified" Binding="{Binding LastModifiedDateTime, StringFormat=g}" Width="140"/>
                <DataGridTextColumn Header="Version" Binding="{Binding Version}" Width="70"/>
            </DataGrid.Columns>
        </DataGrid>

        <GroupBox Grid.Row="2" Header="Configuration Details" Margin="10" Visibility="{Binding SelectedConfiguration, Converter={StaticResource NullToCollapsed}}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="10" DataContext="{Binding SelectedConfiguration}">
                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,6"/>

                    <TextBlock Text="General" FontWeight="SemiBold" Margin="0,8,0,4" Foreground="#0078D4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="ID:" FontWeight="SemiBold" Margin="0,2"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Id}" Margin="0,2"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Profile Type:" FontWeight="SemiBold" Margin="0,2"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ProfileType}" Margin="0,2"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Platform:" FontWeight="SemiBold" Margin="0,2"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Platform}" Margin="0,2"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Version:" FontWeight="SemiBold" Margin="0,2"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Version}" Margin="0,2"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Created:" FontWeight="SemiBold" Margin="0,2"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding CreatedDateTime, StringFormat=g}" Margin="0,2"/>

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Last Modified:" FontWeight="SemiBold" Margin="0,2"/>
                        <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding LastModifiedDateTime, StringFormat=g}" Margin="0,2"/>

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Description:" FontWeight="SemiBold" Margin="0,2"/>
                        <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding Description, FallbackValue='None'}" TextWrapping="Wrap" Margin="0,2"/>
                    </Grid>

                    <!-- Policy Settings -->
                    <TextBlock Text="Policy Settings" FontWeight="SemiBold" Margin="0,16,0,4" Foreground="#0078D4"
                               DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                    <TextBlock Text="{Binding SettingsStatusMessage}" Margin="0,2,0,4" Foreground="#605E5C" FontStyle="Italic"
                               DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}"
                               Visibility="{Binding SettingsStatusMessage, Converter={StaticResource NullToCollapsed}}"/>
                    <DataGrid ItemsSource="{Binding DataContext.PolicySettings, RelativeSource={RelativeSource AncestorType=UserControl}}"
                              AutoGenerateColumns="False" IsReadOnly="True" 
                              MaxHeight="300" CanUserSortColumns="True"
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                              BorderThickness="1" BorderBrush="#EDEBE9">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Setting" Binding="{Binding Name}" Width="350">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextWrapping" Value="Wrap"/>
                                        <Setter Property="Padding" Value="4,2"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextWrapping" Value="Wrap"/>
                                        <Setter Property="Padding" Value="4,2"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Assignments -->
                    <TextBlock Text="Assignments" FontWeight="SemiBold" Margin="0,16,0,4" Foreground="#0078D4"
                               DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                    <TextBlock Text="{Binding AssignmentsStatusMessage}" Margin="0,2,0,4" Foreground="#605E5C" FontStyle="Italic"
                               DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}"
                               Visibility="{Binding AssignmentsStatusMessage, Converter={StaticResource NullToCollapsed}}"/>
                    <DataGrid ItemsSource="{Binding DataContext.ProfileAssignments, RelativeSource={RelativeSource AncestorType=UserControl}}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              MaxHeight="200" CanUserSortColumns="True"
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                              BorderThickness="1" BorderBrush="#EDEBE9">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Group" Binding="{Binding GroupDisplayName}" Width="300"/>
                            <DataGridTextColumn Header="Assignment Type" Binding="{Binding AssignmentType}" Width="120"/>
                            <DataGridTextColumn Header="Group ID" Binding="{Binding GroupId}" Width="280"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </ScrollViewer>
        </GroupBox>
    </Grid>
</UserControl>
