<UserControl x:Class="IntuneAdminTool.Views.ComplianceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Loading compliance data..." Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}" HorizontalAlignment="Center" Margin="0,10"/>
        <StackPanel Orientation="Horizontal" Margin="10" HorizontalAlignment="Center">
            <Border Background="#4CAF50" CornerRadius="5" Padding="20,10" Margin="5">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding CompliantCount}" FontSize="28" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                    <TextBlock Text="Compliant" Foreground="White" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
            <Border Background="#F44336" CornerRadius="5" Padding="20,10" Margin="5">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding NonCompliantCount}" FontSize="28" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                    <TextBlock Text="Non-Compliant" Foreground="White" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
            <Border Background="#9E9E9E" CornerRadius="5" Padding="20,10" Margin="5">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding UnknownCount}" FontSize="28" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                    <TextBlock Text="Unknown" Foreground="White" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </StackPanel>
        <DataGrid Grid.Row="1" ItemsSource="{Binding Devices}" AutoGenerateColumns="False" IsReadOnly="True" Margin="10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Device Name" Binding="{Binding DeviceName}" Width="200"/>
                <DataGridTextColumn Header="User" Binding="{Binding UserDisplayName}" Width="150"/>
                <DataGridTextColumn Header="Compliance" Binding="{Binding ComplianceState}" Width="120"/>
                <DataGridTextColumn Header="OS" Binding="{Binding OperatingSystem}" Width="100"/>
                <DataGridTextColumn Header="Last Sync" Binding="{Binding LastSyncDateTime, StringFormat=g}" Width="160"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
